{
  "name": "devops-demo-app",
  "version": "1.0.0",
  "description": "A simple web application for demonstrating DevOps concepts",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit"
  },
  "keywords": [
    "devops",
    "demo",
    "docker",
    "continuous-deployment"
  ],
  "author": "DevOps Instructor",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
